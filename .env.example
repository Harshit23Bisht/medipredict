# ==============================
# DATABASE CONFIGURATION
# ==============================

# PostgreSQL connection string
POSTGRES_URL=postgresql://username:password@localhost:5432/dbname

# MongoDB connection (used by CNN/image pipeline)
MONGO_URL=mongodb://localhost:27017
MONGO_DB=your_mongo_db_name


# ==============================
# PATH CONFIGURATION
# ==============================

# Where trained models are stored
MODEL_PATH=data/models

# Path to raw MIMIC dataset
MIMIC_RAW_PATH=data/raw